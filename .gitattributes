# Force LF line endings on all source files so SHA-256 manifests generated by
# tools/Verify-Integrity.ps1 are stable across Windows / macOS / Linux checkouts.
# Without this, a Windows checkout with CRLF would compute a different hash than
# the LF source-of-truth, and integrity verification would always fail.
*.ps1   text eol=lf
*.psm1  text eol=lf
*.psd1  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
