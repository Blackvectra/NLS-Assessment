{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://blackvectra.com/schemas/nls-controls-v1.schema.json",
  "title": "NLS Assessment Tool — Control Definition Schema v1.0",
  "description": "Validates Config/controls.json. Every control must pass this schema before merge.",
  "type": "object",
  "required": ["$schema", "version", "generatedAt", "controls"],
  "additionalProperties": false,
  "properties": {
    "$schema":      { "type": "string" },
    "version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "generatedAt":  { "type": "string", "format": "date-time" },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Control" }
    }
  },
  "definitions": {
    "Control": {
      "type": "object",
      "required": [
        "ControlId", "Title", "Description", "BusinessRisk",
        "Severity", "Workload", "Category", "Automated",
        "Profile", "CollectorDependency", "RawDataKeys",
        "EvaluatorFunction", "EvidenceFormat", "Remediation",
        "Frameworks", "MitreAttack", "Tags", "Status",
        "Owner", "ReviewCadenceDays", "LastReviewed"
      ],
      "additionalProperties": false,
      "properties": {
        "ControlId": {
          "type": "string",
          "pattern": "^NLS-(AAD|EXO|DNS|DEF|SPO|TMS|INT|PVW|PPL)-\\d{4}$",
          "description": "NLS-{WORKLOAD}-{NNNN}"
        },
        "Title":        { "type": "string", "minLength": 10, "maxLength": 120 },
        "Description":  { "type": "string", "minLength": 20 },
        "BusinessRisk": { "type": "string", "minLength": 20 },
        "Severity": {
          "type": "string",
          "enum": ["Critical", "High", "Medium", "Low", "Informational"]
        },
        "Workload": {
          "type": "string",
          "enum": ["AAD", "EXO", "DNS", "DEF", "SPO", "TMS", "INT", "PVW", "PPL"]
        },
        "Category": {
          "type": "string",
          "enum": ["Identity", "Email", "Endpoint", "Data", "Collaboration", "Governance", "Network"]
        },
        "Automated": { "type": "boolean" },
        "Profile": {
          "type": "array",
          "items": { "type": "string", "enum": ["E3-L1", "E3-L2", "E5-L1", "E5-L2", "All"] },
          "minItems": 1
        },
        "CollectorDependency": {
          "type": "array",
          "items": { "type": "string" }
        },
        "RawDataKeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "EvaluatorFunction": { "type": "string", "pattern": "^Test-NLSControl-" },
        "EvidenceFormat": {
          "type": "object",
          "required": ["Type", "RequiredProperties"],
          "properties": {
            "Type":               { "type": "string" },
            "RequiredProperties": { "type": "array", "items": { "type": "string" } },
            "Schema":             { "type": "string" }
          }
        },
        "Remediation": {
          "type": "object",
          "required": ["Summary", "EffortHours", "EffortLevel", "ExternalRefs"],
          "properties": {
            "Summary":        { "type": "string" },
            "EffortHours":    { "type": "integer", "minimum": 0 },
            "EffortLevel":    { "type": "string", "enum": ["Quick", "Standard", "Significant", "Major"] },
            "RemediationDocId": { "type": ["string", "null"] },
            "ExternalRefs":   { "type": "array", "items": { "type": "string" } },
            "RollbackPlan":   { "type": ["string", "null"] }
          }
        },
        "Frameworks": {
          "type": "object",
          "properties": {
            "CIS-M365-v6.0.1":  { "$ref": "#/definitions/FrameworkRef" },
            "CISA-SCuBA-M365":  { "$ref": "#/definitions/FrameworkRef" },
            "NIST-800-53-r5":   { "$ref": "#/definitions/FrameworkRef" },
            "NIST-800-171-r2":  { "$ref": "#/definitions/FrameworkRef" },
            "CMMC-2.0-L2":      { "$ref": "#/definitions/FrameworkRef" },
            "HIPAA-SR":         { "$ref": "#/definitions/FrameworkRef" },
            "OWASP-Top10-2025": { "$ref": "#/definitions/FrameworkRef" },
            "OWASP-ASVS-v5":    { "$ref": "#/definitions/FrameworkRef" },
            "OSSTMM-v3":        { "$ref": "#/definitions/FrameworkRef" }
          },
          "additionalProperties": false
        },
        "MitreAttack": {
          "type": "array",
          "items": { "type": "string", "pattern": "^T\\d{4}(\\.\\d{3})?$" }
        },
        "Tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Status": {
          "type": "string",
          "enum": ["Active", "Draft", "Deprecated"]
        },
        "DeprecatedBy": { "type": ["string", "null"] },
        "Owner":               { "type": "string" },
        "ReviewCadenceDays":   { "type": "integer", "minimum": 30 },
        "LastReviewed":        { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "FrameworkRef": {
      "type": "object",
      "required": ["controls", "relationship"],
      "properties": {
        "controls":     { "type": "array", "items": { "type": "string" } },
        "relationship": { "type": "string", "enum": ["equivalent-to", "subset-of", "intersects-with", "superset-of"] },
        "baselineVersion": { "type": "string" },
        "notes":        { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
